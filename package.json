{
  "name": "fast-food-ecommerce",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^5.3.0",
    "axios": "^0.21.1",
    "redux": "^4.1.0",
    "react-redux": "^7.2.5",
    "tailwindcss": "^2.2.19",
    "classnames": "^2.3.1"
  },
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run admin\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "admin": "cd admin && npm start",
    "client": "cd client && npm start",
    "install-all": "npm install && cd server && npm install && cd ../admin && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}